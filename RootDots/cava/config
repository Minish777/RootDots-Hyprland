[general]
# Частота кадров для плавности
framerate = 60
# Автоматическая настройка чувствительности
autosens = 1
# Количество полос (0 = на весь терминал)
bars = 0
bar_width = 2
bar_spacing = 1

[input]
# Для большинства современных систем (Arch/CachyOS) используем pipewire
method = pipewire
source = auto

[output]
# noncurses работает стабильнее и меньше мерцает
method = noncurses
channels = stereo

[color]
# Включаем градиент под лесную тему
gradient = 1
# Переход от зеленого основания к туманным верхушкам
gradient_color_1 = '#6c8c72'
gradient_color_2 = '#7da385'
gradient_color_3 = '#8eb998'
gradient_color_4 = '#9fcfab'
gradient_color_5 = '#b0e5be'
gradient_color_6 = '#cbd5d0'

[smoothing]
# Современный параметр для мягкости анимации (вместо старых gravity/integral)
noise_reduction = 77
monstercat = 1

[eq]
# Стандартный баланс частот
1 = 1
2 = 1
3 = 1
4 = 1
5 = 1
